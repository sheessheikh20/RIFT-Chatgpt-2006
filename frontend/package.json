{
  "name": "chatgpt-professional-enterprise-suite",
  "private": true,
  "version": "1.0.0",
  "description": "ChatGPT Professional Enterprise Suite 2006",
  "author": "OpenAI",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc --project electron/tsconfig.json",
    "dev:electron": "concurrently \"vite\" \"wait-on tcp:5173 && npm run build:electron && electron .\"",
    "package": "npm run build && npm run build:electron && electron-builder --config electron-builder.yml",
    "package:clean": "rmdir /s /q release 2>nul & npm run package",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
